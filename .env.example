# Database deployment configuration
DIALECT= # Database dialect to use (e.g., mssql, postgresql)

DB_USERNAME= # Database username
DB_PASSWORD= # Database password
HOST= # Hostname of the database server (e.g., docker service name)
INTERNAL_PORT= # Port the database listens on inside the container
EXTERNAL_PORT= # Port to expose the database on the host machine

RESTORE_POINT_INTERVAL_MINUTES= # How often (in minutes) to take a timed backup
RESTORE_POINT_RETENTION= # How many backups to keep (0 = keep all)

TYPE=none
SQL_PROJECT_DIRECTORY=# Directory on the host machine containing SQL scripts to execute during initialization
RESTORE_POINT_DIRECTORY=# Directory on the host machine containing backup files to restore
O=bind